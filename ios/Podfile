# Match Android's newArchEnabled=false (android/gradle.properties) so both platforms build old-architecture.
ENV['RCT_NEW_ARCH_ENABLED'] = '0'

def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

node_require('react-native/scripts/react_native_pods.rb')
node_require('react-native-permissions/scripts/setup.rb')

# @react-native-ml-kit/text-recognition (GoogleMLKit/TextRecognition 8.0.0) requires iOS 15.5+
platform :ios, '15.5'
prepare_react_native_project!

setup_permissions([
  'Notifications',
  'PhotoLibrary',
  'PhotoLibraryAddOnly',
  'Camera',
  'Microphone',
])

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'LitNotesCanvas' do
  config = use_native_modules!

  # Required by Google Sign-In / AppCheckCore Swift pods when linking as static libs.
  pod 'GoogleUtilities', :modular_headers => true
  pod 'RecaptchaInterop', :modular_headers => true

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'LitNotesCanvasTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Apple Silicon requires arm64 simulator builds. Xcode 26 no longer
    # surfaces usable x86_64 simulator destinations, so CocoaPods' default
    # EXCLUDED_ARCHS[sdk=iphonesimulator*]=arm64 must be cleared — except for
    # Google ML Kit pods, whose prebuilt arm64 slices are device-only.
    mlkit_targets = %w[
      RNMLKitTextRecognition
      MLImage
      MLKitCommon
      MLKitVision
      MLKitTextRecognition
      MLKitTextRecognitionCommon
      MLKitTextRecognitionChinese
      MLKitTextRecognitionJapanese
      MLKitTextRecognitionKorean
      MLKitTextRecognitionDevanagari
      GoogleMLKit
    ]
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |config|
        if mlkit_targets.include?(target.name)
          config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = 'arm64 x86_64'
        else
          config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = ''
        end
      end
    end
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', '**', '*.xcconfig')).each do |path|
      contents = File.read(path)
      new_contents = contents.gsub(
        /^EXCLUDED_ARCHS\[sdk=iphonesimulator\*\]\s*=.*$/,
        'EXCLUDED_ARCHS[sdk=iphonesimulator*] ='
      )
      File.write(path, new_contents) if new_contents != contents
    end

    # Strip ML Kit from the app's simulator link line (device builds keep OCR).
    # Do NOT keep $(inherited) here — it would re-pull the base OTHER_LDFLAGS
    # (with ML Kit) and defeat the filter.
    Dir.glob(File.join(installer.sandbox.root, 'Target Support Files', 'Pods-LitNotesCanvas', '*.xcconfig')).each do |path|
      contents = File.read(path)
      next unless contents =~ /^OTHER_LDFLAGS = (.*)$/
      flags = Regexp.last_match(1)
      contents = contents.gsub(/^OTHER_LDFLAGS\[sdk=iphonesimulator\*\] = .*$\n?/, '')
      sim_flags = flags
        .gsub(/\$\(inherited\)\s*/, '')
        .gsub(/-l"RNMLKitTextRecognition"\s*/, '')
        .gsub(/-framework "MLImage"\s*/, '')
        .gsub(/-framework "MLKit[^"]*"\s*/, '')
      File.write(path, contents.rstrip + "\nOTHER_LDFLAGS[sdk=iphonesimulator*] = #{sim_flags}\n")
    end
  end
end
